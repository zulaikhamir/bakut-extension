{
  "manifest_version": 3,
  "name": "bakut",
  "version": "1.2",
  "description": "your emotional support duck for leetcode",
  "permissions": ["storage", "alarms"],
  "background": {
    "service_worker": "background.js"
  },
  "host_permissions": ["https://leetcode.com/*"],
  "content_scripts": [
    {
      "matches": ["https://leetcode.com/*"],
      "js": ["content.js"]
    }
  ],
  "action": {
    "default_popup": "popup.html"
  }
}
